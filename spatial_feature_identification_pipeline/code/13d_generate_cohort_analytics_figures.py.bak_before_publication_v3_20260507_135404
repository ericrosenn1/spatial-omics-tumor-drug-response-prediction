def figure_pairwise_relationship_counts(pair_df: pd.DataFrame, out_dir: Path) -> Path:
    """Generate publication-ready pairwise relationship summaries.

    The source table is motif-pair-level when sample_id is absent. Therefore the
    main figure is a relationship composition bar chart rather than a misleading
    sample heatmap. A companion heatmap by motif pair is also written.
    """
    require_column(pair_df, "relationship", "all_pair_table")
    temp = pair_df.copy()

    if "count" in temp.columns:
        temp["count"] = pd.to_numeric(temp["count"], errors="coerce").fillna(0.0)
        weight_col = "count"
    else:
        temp["count"] = 1.0
        weight_col = "count"

    if "pair" not in temp.columns and {"motif_a", "motif_b"}.issubset(temp.columns):
        temp["pair"] = temp["motif_a"].astype(str).map(clean_text_label) + " vs " + temp["motif_b"].astype(str).map(clean_text_label)
    elif "pair" in temp.columns:
        temp["pair"] = temp["pair"].astype(str).str.replace("_", " ", regex=False)
    else:
        temp["pair"] = "all motif pairs"

    summary = temp.groupby("relationship", dropna=False)[weight_col].sum().reset_index(name="count")
    order = [r for r in RELATIONSHIP_ORDER if r in summary["relationship"].astype(str).tolist()]
    order += [r for r in summary["relationship"].astype(str).tolist() if r not in order]
    summary["relationship"] = pd.Categorical(summary["relationship"].astype(str), categories=order, ordered=True)
    summary = summary.sort_values("relationship")
    total = float(summary["count"].sum()) if float(summary["count"].sum()) else 1.0
    summary["fraction"] = summary["count"] / total
    write_table(summary, out_dir / "tables" / "10_pairwise_motif_relationship_counts.csv")

    fig, ax = plt.subplots(figsize=(6.2, 4.5))
    labels = [clean_text_label(x) for x in summary["relationship"].astype(str).tolist()]
    values = summary["fraction"].astype(float).tolist()
    ax.bar(labels, values)
    ax.set_ylabel("Fraction of pairwise relationships")
    ax.set_title("Pairwise motif relationship composition")
    ax.set_ylim(0, max(values) * 1.25 if values else 1)
    ax.grid(axis="y", alpha=0.25)
    for i, (value, count) in enumerate(zip(values, summary["count"].astype(float).tolist())):
        ax.text(i, value, f"{value:.2f}\nn={int(count)}", ha="center", va="bottom", fontsize=8)
    out_path = out_dir / "figures" / "10_pairwise_motif_relationship_counts.png"
    save_figure(fig, out_path)

    pivot = temp.pivot_table(index="pair", columns="relationship", values=weight_col, aggfunc="sum", fill_value=0.0)
    pivot = pivot.reindex(columns=order, fill_value=0.0)
    pivot["total"] = pivot.sum(axis=1)
    pivot = pivot.sort_values("total", ascending=False).drop(columns=["total"])
    top_pivot = pivot.head(40)
    write_table(pivot.reset_index(), out_dir / "tables" / "10b_pairwise_motif_relationship_by_pair.csv")
    heat_path = out_dir / "figures" / "10b_pairwise_motif_relationship_by_pair_heatmap.png"
    make_heatmap(top_pivot, "Top motif-pair relationship counts", heat_path, cbar_label="Count", show_y_labels=True, x_label_max_len=16)
    return out_path


