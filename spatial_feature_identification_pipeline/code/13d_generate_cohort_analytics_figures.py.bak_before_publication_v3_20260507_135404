    require_column(pair_df, "motif_b", "all_pair_table")
    require_column(pair_df, "centroid_distance", "all_pair_table")
    motifs = ordered_motif_labels(sorted(set(pair_df["motif_a"].astype(str)) | set(pair_df["motif_b"].astype(str))))
    matrix = pd.DataFrame(np.nan, index=motifs, columns=motifs, dtype=float)
    for motif in motifs:
        matrix.loc[motif, motif] = 0.0
    grouped = pair_df.groupby(["motif_a", "motif_b"], dropna=False)["centroid_distance"].mean().reset_index()
    for _, row in grouped.iterrows():
        a = str(row["motif_a"])
        b = str(row["motif_b"])
        value = float(row["centroid_distance"]) if pd.notna(row["centroid_distance"]) else np.nan
        if a in matrix.index and b in matrix.columns:
            matrix.loc[a, b] = value
            matrix.loc[b, a] = value
    clean_index = [clean_text_label(x) for x in matrix.index]
    matrix.index = clean_index
    matrix.columns = clean_index
    write_table(matrix.reset_index().rename(columns={"index": "motif"}), out_dir / "tables" / "09_mean_centroid_distance_matrix.csv")
