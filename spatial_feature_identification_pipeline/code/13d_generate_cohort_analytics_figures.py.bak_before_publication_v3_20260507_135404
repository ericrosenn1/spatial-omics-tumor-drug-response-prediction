def figure_pca_explained_variance(model_df: pd.DataFrame, feature_manifest: pd.DataFrame | None, out_dir: Path, top_components: int) -> Path:
    matrix, _, notes = numeric_feature_matrix(model_df, feature_manifest)
    if matrix.shape[0] < 3 or matrix.shape[1] < 2:
        raise ValueError("Need at least 3 samples and 2 numeric spatial features for PCA")
    x = standardize_matrix(matrix)
    n_components = min(top_components, x.shape[0] - 1, x.shape[1])
    if HAS_SKLEARN:
        pca = PCA(n_components=n_components)
        pca.fit(x)
        explained = pca.explained_variance_ratio_
    else:
        _, s, _ = np.linalg.svd(x, full_matrices=False)
        variances = (s ** 2) / max(1, x.shape[0] - 1)
        explained = (variances / variances.sum())[:n_components]
    cumulative = np.cumsum(explained)
    table = pd.DataFrame({
        "component": np.arange(1, len(explained) + 1),
        "explained_variance_ratio": explained,
        "cumulative_explained_variance_ratio": cumulative,
    })
    table["feature_source_note"] = ";".join(notes)
    table["n_features_used"] = matrix.shape[1]
    write_table(table, out_dir / "tables" / "01_pca_explained_variance.csv")

    fig, ax = plt.subplots(figsize=(8, 5))
    ax.bar(table["component"], table["explained_variance_ratio"], label="Individual PC")
    ax.plot(table["component"], table["cumulative_explained_variance_ratio"], marker="o", label="Cumulative")
    ax.set_title("PCA variance structure")
    ax.set_xlabel("Principal component")
    ax.set_ylabel("Explained variance ratio")
    ax.set_ylim(0, 1.0)
    ax.set_xticks(table["component"])
    ax.tick_params(axis="x", labelrotation=0)
    ax.grid(axis="y", alpha=0.25)
    ax.legend(frameon=False, loc="lower right")
    pc1 = explained[0]
    last = cumulative[-1]
    ax.text(0.02, 0.96, f"PC1 = {pc1:.2%}\nPC1–{n_components} = {last:.2%}\nfeatures = {matrix.shape[1]}",
            transform=ax.transAxes, va="top", ha="left")
    out_path = out_dir / "figures" / "01_pca_explained_variance.png"
    save_figure(fig, out_path)
    return out_path


def figure_top_variable_feature_heatmap(model_df: pd.DataFrame, feature_manifest: pd.DataFrame | None, out_dir: Path, top_n: int) -> Path:
    matrix, sample_ids, notes = numeric_feature_matrix(model_df, feature_manifest)
    if matrix.shape[0] < 2 or matrix.shape[1] < 2:
        raise ValueError("Need at least 2 samples and 2 numeric features for heatmap")
    variances = matrix.var(axis=0).sort_values(ascending=False)
    top_cols = variances.head(top_n).index.tolist()
    sub = matrix[top_cols].copy()
    z = pd.DataFrame(standardize_matrix(sub), index=sample_ids, columns=top_cols)

    row_order = np.arange(z.shape[0])
    col_order = np.arange(z.shape[1])
    if HAS_SCIPY_CLUSTER and z.shape[0] >= 3 and z.shape[1] >= 3:
        with warnings.catch_warnings():
            warnings.simplefilter("ignore")
            row_dist = pdist(z.to_numpy(dtype=float), metric="euclidean")
            col_dist = pdist(z.T.to_numpy(dtype=float), metric="euclidean")
            if np.isfinite(row_dist).all() and np.any(row_dist > 0):
                row_order = leaves_list(linkage(row_dist, method="average"))
            if np.isfinite(col_dist).all() and np.any(col_dist > 0):
                col_order = leaves_list(linkage(col_dist, method="average"))
    clustered = z.iloc[row_order, col_order]

    feature_table = pd.DataFrame({
        "feature": top_cols,
        "clean_feature_label": [clean_feature_label(c) for c in top_cols],
        "feature_class_inferred": [infer_feature_class(c) for c in top_cols],
        "variance": variances.loc[top_cols].values,
        "feature_source_note": ";".join(notes),
    })
    if feature_manifest is not None and not feature_manifest.empty:
        name_col = safe_col(feature_manifest, FEATURE_NAME_CANDIDATES)
        group_col = safe_col(feature_manifest, FEATURE_GROUP_CANDIDATES)
        if name_col and group_col:
            map_df = feature_manifest[[name_col, group_col]].drop_duplicates()
            map_df.columns = ["feature", "feature_group"]
            feature_table = feature_table.merge(map_df, on="feature", how="left")
    write_table(feature_table, out_dir / "tables" / "02_top_variable_features.csv")
    write_table(clustered.reset_index().rename(columns={"index": "sample_id"}), out_dir / "tables" / "02_top_variable_feature_heatmap_zscores.csv")

    out_path = out_dir / "figures" / "02_top_variable_feature_heatmap.png"
    show_y = clustered.shape[0] <= 35
    make_feature_heatmap_with_class_strip(
        clustered,
        "Top-variable spatial architecture features",
        out_path,
        cbar_label="Feature-wise z-score",
        show_y_labels=show_y,
        x_label_max_len=18,
    )
    return out_path


