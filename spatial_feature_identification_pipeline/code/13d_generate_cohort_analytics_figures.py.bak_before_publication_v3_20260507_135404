    summary_path = out_dir / "cohort_analytics_summary.txt"
    metadata_path = out_dir / "cohort_analytics_metadata.json"
    write_manifest(rows, manifest_path)
    write_summary(summary_path, args, output_root, out_dir, rows, input_paths)
    metadata = {
        "script": SCRIPT_NAME,
        "timestamp": stamp,
        "pipeline_root": str(pipeline_root),
        "config": str(config_path),
        "output_root": str(output_root),
        "output_folder": str(out_dir),
        "top_n_features": args.top_n_features,
        "max_pca_components": args.max_pca_components,
        "max_labels_main": args.max_labels_main,
        "has_sklearn": HAS_SKLEARN,
        "has_scipy_cluster": HAS_SCIPY_CLUSTER,
        "has_scipy_stats": HAS_SCIPY_STATS,
        "figures_created": sum(1 for row in rows if row["status"] == "created"),
        "figures_requested": len(rows),
    }
    metadata_path.write_text(json.dumps(metadata, indent=2), encoding="utf-8")

    created = sum(1 for row in rows if row["status"] == "created")
    failed = [row for row in rows if row["status"] != "created"]
    print("=" * 60)
    print("Cohort analytics figure summary")
    print("=" * 60)
    print("Figures requested:", len(rows))
    print("Figures created:", created)
    print("Figures skipped or failed:", len(failed))
    print("Output folder:", out_dir)
    print("Figure folder:", out_dir / "figures")
    print("Table folder:", out_dir / "tables")
    print("Manifest:", manifest_path)
    print("Summary:", summary_path)
    print("Metadata:", metadata_path)
    if failed:
        print("Skipped or failed figures:")
        for row in failed:
            print(f"  {row['figure_id']} | {row['status']} | {row['message']}")
    print("DONE")
    if not args.no_open:
        open_folder(out_dir)
        open_folder(out_dir / "figures")


if __name__ == "__main__":
    with warnings.catch_warnings():
        warnings.simplefilter("ignore")
