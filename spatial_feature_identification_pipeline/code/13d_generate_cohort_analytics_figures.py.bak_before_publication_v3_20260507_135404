def write_summary(path: Path, args: argparse.Namespace, output_root: Path, out_dir: Path, rows: list[dict], input_paths: dict[str, Path]) -> None:
    success = sum(1 for r in rows if r["status"] == "created")
    skipped = sum(1 for r in rows if r["status"] != "created")
    lines = [
        str(path),
        "",
        "Cohort analytics figure generation summary",
        "",
        f"Script: {SCRIPT_NAME}",
        f"Timestamp: {datetime.now().isoformat(timespec='seconds')}",
        f"Output root: {output_root}",
        f"Output folder: {out_dir}",
        "",
        "Important generation notes:",
        "  - PCA and heatmap use retained/intersecting feature-manifest columns when available.",
        "  - PCA and heatmap exclude IDs, metadata, treatment/teacher/response fields, QC/status fields, and low-information numeric columns.",
        "  - Figure 02 is a cluster-ordered heatmap with an inferred feature-class annotation strip, not a dendrogram clustermap.",
        "  - Label frequency is cleaned for readability, and an additional collapsed biological-category plot is produced.",
        "  - Glycolysis/hypoxia scatter includes Pearson r, p value when scipy.stats is available, regression line, and n.",
        "",
        "Input files:",
    ]
    for key, value in input_paths.items():
        lines.append(f"  {key}: {value} | exists={value.exists()}")
    lines.extend([
        "",
        f"Figures requested: {len(rows)}",
        f"Figures created: {success}",
        f"Figures skipped or failed: {skipped}",
        "",
        "Figure status:",
    ])
    for row in rows:
        lines.append(f"  {row['figure_id']}: {row['status']} | {row['message']} | {row['figure_path']}")
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


