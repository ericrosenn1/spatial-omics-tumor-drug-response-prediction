    gs = fig.add_gridspec(nrows=2, ncols=1, height_ratios=[0.22, 4.8], hspace=0.04)
    ax_strip = fig.add_subplot(gs[0])
    ax = fig.add_subplot(gs[1])

    ax_strip.imshow(strip, aspect="auto", cmap=cmap, vmin=0, vmax=len(class_order) - 1, interpolation="nearest")
    ax_strip.set_xticks([])
    ax_strip.set_yticks([])
    ax_strip.set_ylabel("Class", rotation=0, ha="right", va="center", fontsize=8)

