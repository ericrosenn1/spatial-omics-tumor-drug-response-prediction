def is_excluded_feature(column: str) -> bool:
    col = str(column)
    low = col.lower()
    if low in EXACT_EXCLUDE_COLUMNS:
        return True
    if low.endswith("_id") and low not in {"spatial_id"}:
        return True
    if low.startswith(EXCLUDE_PREFIXES):
        return True
    if any(term in low for term in EXCLUDE_SUBSTRINGS):
        return True
    return False


def retention_mask_from_manifest(feature_manifest: pd.DataFrame) -> pd.Series:
    keep = pd.Series(True, index=feature_manifest.index)
    retention_col = safe_col(feature_manifest, RETENTION_COLUMN_CANDIDATES)
    if retention_col is not None:
        values = feature_manifest[retention_col]
        if pd.api.types.is_bool_dtype(values):
            keep &= values.fillna(False)
        else:
            text = values.astype(str).str.lower().str.strip()
            negative = text.isin({
                "false", "0", "no", "n", "drop", "dropped", "remove", "removed",
                "exclude", "excluded", "filtered", "not_retained", "not retained", "fail", "failed"
            })
            positive = text.isin({
                "true", "1", "yes", "y", "keep", "kept", "retain", "retained",
                "include", "included", "ok", "pass", "passed", "model", "model_ready"
            })
            if positive.any():
                keep &= positive
            else:
                keep &= ~negative
    return keep


def feature_columns_from_manifest(model_df: pd.DataFrame, feature_manifest: pd.DataFrame | None) -> list[str]:
    if feature_manifest is None or feature_manifest.empty:
        return []

    name_col = safe_col(feature_manifest, FEATURE_NAME_CANDIDATES)
    if name_col is None:
        return []

    keep_mask = retention_mask_from_manifest(feature_manifest)
    candidate_names = feature_manifest.loc[keep_mask, name_col].astype(str).tolist()
    cols = [c for c in candidate_names if c in model_df.columns and not is_excluded_feature(c)]
    return list(dict.fromkeys(cols))


def numeric_feature_matrix(
    df: pd.DataFrame,
    feature_manifest: pd.DataFrame | None = None,
    sample_col: str = "sample_id",
) -> tuple[pd.DataFrame, list[str], list[str]]:
    if sample_col in df.columns:
        sample_ids = df[sample_col].astype(str).tolist()
    else:
        sample_ids = [f"row_{i}" for i in range(len(df))]

    manifest_cols = feature_columns_from_manifest(df, feature_manifest)
    if len(manifest_cols) >= 2:
        candidate_cols = manifest_cols
        source = "feature_manifest_retained_intersection"
    else:
        candidate_cols = [c for c in df.columns if c != sample_col and not is_excluded_feature(c)]
        source = "numeric_columns_after_exclusions"

    numeric = pd.DataFrame(index=df.index)
    dropped = []
    for col in candidate_cols:
        values = pd.to_numeric(df[col], errors="coerce")
        nonmissing_fraction = float(values.notna().mean())
        if nonmissing_fraction < MIN_NONMISSING_FRACTION:
            dropped.append(f"{col}|low_nonmissing")
            continue
        if values.nunique(dropna=True) < 2:
            dropped.append(f"{col}|constant")
            continue
        numeric[col] = values

    if numeric.empty:
        return numeric, sample_ids, [source]

    medians = numeric.median(axis=0, skipna=True)
    numeric = numeric.fillna(medians)
    numeric = numeric.replace([np.inf, -np.inf], np.nan).fillna(0.0)
    notes = [source, f"dropped_after_qc={len(dropped)}"]
    return numeric, sample_ids, notes


def standardize_matrix(matrix: pd.DataFrame) -> np.ndarray:
    arr = matrix.to_numpy(dtype=float)
    if HAS_SKLEARN:
        return StandardScaler().fit_transform(arr)
    mean = np.nanmean(arr, axis=0)
    std = np.nanstd(arr, axis=0)
    std[std == 0] = 1.0
    return (arr - mean) / std


