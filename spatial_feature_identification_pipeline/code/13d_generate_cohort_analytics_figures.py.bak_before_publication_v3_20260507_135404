def make_horizontal_boxplot(
    data_by_group: dict[str, pd.Series],
    title: str,
    xlabel: str,
    out_path: Path,
    order: list[str] | None = None,
    show_points: bool = False,
    annotate_n: bool = False,
) -> None:
    labels = []
    values = []
    keys = list(data_by_group.keys())
    if order:
        ordered_keys = [k for k in order if k in data_by_group]
        ordered_keys += [k for k in keys if k not in ordered_keys]
        keys = ordered_keys
    for label in keys:
        vals = pd.to_numeric(data_by_group[label], errors="coerce").dropna().to_numpy(dtype=float)
        if vals.size == 0:
            continue
        shown_label = str(label)
        if annotate_n:
            shown_label = f"{shown_label} (n={vals.size})"
        labels.append(shown_label)
        values.append(vals)
    if not values:
        raise ValueError("No nonmissing values available for boxplot")
    fig_h = max(5, len(labels) * 0.48 + 1.5)
    fig, ax = plt.subplots(figsize=(8.2, fig_h))
    positions = np.arange(1, len(values) + 1)
    ax.boxplot(values, labels=labels, vert=False, showfliers=False, positions=positions)
    if show_points:
        rng = np.random.default_rng(7)
        for pos, vals in zip(positions, values):
            jitter = rng.normal(0, 0.045, size=len(vals))
            ax.scatter(vals, pos + jitter, s=14, alpha=0.55, linewidths=0)
    ax.set_title(title)
    ax.set_xlabel(xlabel)
    ax.grid(axis="x", alpha=0.25)
    save_figure(fig, out_path)


def make_hist(
    values: pd.Series,
    title: str,
    xlabel: str,
    out_path: Path,
    bins: int | np.ndarray = 20,
    xlim: tuple[float, float] | None = None,
    annotate: bool = True,
) -> None:
    vals = pd.to_numeric(values, errors="coerce").dropna().to_numpy(dtype=float)
    if vals.size == 0:
        raise ValueError("No nonmissing values available for histogram")
    fig, ax = plt.subplots(figsize=(7.2, 5.0))
    ax.hist(vals, bins=bins)
    if xlim is not None:
        ax.set_xlim(*xlim)
    median = float(np.median(vals))
    ax.axvline(median, linestyle="--", linewidth=1.5)
    ax.set_title(title)
    ax.set_xlabel(xlabel)
    ax.set_ylabel("Sample count")
    if annotate:
        q1, q3 = np.percentile(vals, [25, 75])
        ax.text(0.98, 0.95, f"n = {vals.size}\nmedian = {median:.3f}\nIQR = {q1:.3f}–{q3:.3f}", transform=ax.transAxes, va="top", ha="right")
    ax.grid(axis="y", alpha=0.25)
    save_figure(fig, out_path)


