def canonical_key(label: str) -> str:
    """Return lowercase underscore key for ordering and validation."""
    return re.sub(r"[^a-z0-9]+", "_", str(label).strip().lower()).strip("_")


def ordered_profile_labels(labels: list[str]) -> list[str]:
    """Order accessibility labels consistently across panels."""
    label_map = {canonical_key(x): x for x in labels}
    ordered = [label_map[k] for k in ACCESSIBILITY_PROFILE_ORDER if k in label_map]
    extra = [x for x in labels if canonical_key(x) not in ACCESSIBILITY_PROFILE_ORDER]
    return ordered + sorted(extra, key=str)


def ordered_motif_labels(labels: list[str]) -> list[str]:
    """Order motifs consistently across motif panels."""
    label_map = {canonical_key(x): x for x in labels}
    ordered = [label_map[k] for k in MOTIF_ORDER if k in label_map]
    extra = [x for x in labels if canonical_key(x) not in MOTIF_ORDER]
    return ordered + sorted(extra, key=str)


def motif_fraction_validation_from_pivot(pivot: pd.DataFrame) -> pd.DataFrame:
    """Summarize motif fraction distributions and flag low-variance motifs."""
    rows = []
    for motif in pivot.columns:
        values = pd.to_numeric(pivot[motif], errors="coerce")
        rows.append({
            "motif": motif,
            "clean_motif": clean_text_label(motif),
            "n": int(values.notna().sum()),
            "mean": float(values.mean()),
            "median": float(values.median()),
            "std": float(values.std(ddof=1)) if values.notna().sum() > 1 else 0.0,
            "min": float(values.min()),
            "max": float(values.max()),
            "n_zero": int((values.fillna(0) == 0).sum()),
            "flag_low_variance": bool((values.std(ddof=1) if values.notna().sum() > 1 else 0.0) < LOW_VARIANCE_MOTIF_STD_THRESHOLD),
        })
    return pd.DataFrame(rows)


def write_validation_report(out_dir: Path, validation_rows: list[dict]) -> None:
    """Write a compact validation report for Figures 4 and 5 source tables."""
    if not validation_rows:
        validation_rows = [{"check": "validation", "status": "not_run", "message": "No validation checks were recorded."}]
    table = pd.DataFrame(validation_rows)
    write_table(table, out_dir / "tables" / "figure4_5_validation_report.csv")
    lines = ["Figure 4/5 validation report", "", "check\tstatus\tmessage"]
    for row in validation_rows:
        lines.append(f"{row.get('check','')}\t{row.get('status','')}\t{row.get('message','')}")
    (out_dir / "tables" / "figure4_5_validation_report.txt").write_text("\n".join(lines) + "\n", encoding="utf-8")


def validate_figure4_5_inputs(tables: dict[str, pd.DataFrame | None], out_dir: Path) -> None:
    """Validate Figure 4/5 source tables before plotting.

    These checks are descriptive: they flag low-variance motif fraction columns,
    range violations, small-n accessibility groups, missing relationship classes,
    and hotspot fragmentation scale problems. They do not change upstream data.
    """
    rows: list[dict] = []

    motif_df = tables.get("motif_table")
    if motif_df is not None and {"sample_id", "motif", "fraction_of_slide"}.issubset(motif_df.columns):
        pivot = motif_df.pivot_table(index="sample_id", columns="motif", values="fraction_of_slide", aggfunc="mean").fillna(0.0)
        summary = motif_fraction_validation_from_pivot(pivot)
        write_table(summary, out_dir / "tables" / "06_motif_fraction_validation.csv")
        low = summary.loc[summary["flag_low_variance"], "clean_motif"].tolist()
        bad_range = summary[(summary["min"] < -1e-8) | (summary["max"] > 1 + 1e-8)]["clean_motif"].tolist()
        rows.append({
            "check": "motif_fraction_low_variance",
            "status": "warn" if low else "ok",
            "message": "; ".join(low) if low else "No low-variance motif-fraction columns detected.",
        })
        rows.append({
            "check": "motif_fraction_range_0_1",
            "status": "fail" if bad_range else "ok",
            "message": "; ".join(bad_range) if bad_range else "All motif fractions are within [0, 1].",
        })
    else:
        rows.append({"check": "motif_fraction_inputs", "status": "missing", "message": "motif_table missing required columns."})

    pair_df = tables.get("pair_table")
    if pair_df is not None and "relationship" in pair_df.columns:
        relationships = sorted(pair_df["relationship"].dropna().astype(str).unique().tolist())
        missing = [r for r in RELATIONSHIP_ORDER if r not in relationships]
        rows.append({
            "check": "pairwise_relationship_classes",
            "status": "warn" if missing else "ok",
            "message": f"observed={relationships}; missing_expected={missing}",
        })
        if "sample_id" in pair_df.columns:
            rows.append({"check": "pairwise_sample_rows", "status": "ok", "message": f"sample_id present; n_samples={pair_df['sample_id'].nunique()}"})
        else:
            rows.append({"check": "pairwise_sample_rows", "status": "warn", "message": "sample_id absent; relationship heatmap will be motif-pair-level, not sample-level."})
    else:
        rows.append({"check": "pairwise_inputs", "status": "missing", "message": "pair_table missing relationship column."})

    access_df = tables.get("accessibility_profiles")
    if access_df is not None:
        label_col = safe_col(access_df, ["access_profile_label", "profile_label"])
        if label_col:
            counts = access_df[label_col].astype(str).value_counts()
            small = counts[counts < 10]
            rows.append({
                "check": "accessibility_profile_group_sizes",
                "status": "warn" if len(small) else "ok",
                "message": "; ".join([f"{clean_text_label(k)} n={int(v)}" for k, v in small.items()]) if len(small) else "All accessibility groups have n >= 10.",
            })
        else:
            rows.append({"check": "accessibility_profile_label", "status": "missing", "message": "No accessibility profile column found."})
    else:
        rows.append({"check": "accessibility_inputs", "status": "missing", "message": "accessibility profile table not found."})

    hotspot_df = tables.get("hotspot_summary")
    if hotspot_df is not None:
        frag_cols = [c for c in hotspot_df.columns if str(c).endswith("_fragmentation_index")]
        for col in frag_cols:
            vals = pd.to_numeric(hotspot_df[col], errors="coerce")
            n = int(vals.notna().sum())
            mx = float(vals.max()) if n else float("nan")
            status = "warn" if (n < 10 or mx > HOTSPOT_FRAGMENTATION_XLIM[1]) else "ok"
            rows.append({
                "check": f"hotspot_fragmentation_{col}",
                "status": status,
                "message": f"n_nonmissing={n}; max={mx:.3g}; common_axis={HOTSPOT_FRAGMENTATION_XLIM}",
            })
    else:
        rows.append({"check": "hotspot_inputs", "status": "missing", "message": "hotspot summary table not found."})

    concordance_df = tables.get("metabolic_concordance")
    if concordance_df is not None:
        col = safe_col(concordance_df, ["concordance__overall_mean", "overall_metabolic_concordance"])
        if col:
            vals = pd.to_numeric(concordance_df[col], errors="coerce")
            rows.append({"check": "metabolic_concordance", "status": "ok", "message": f"n={int(vals.notna().sum())}; median={float(vals.median()):.3f}"})
        else:
            rows.append({"check": "metabolic_concordance", "status": "missing", "message": "No overall concordance column found."})
    else:
        rows.append({"check": "metabolic_concordance_inputs", "status": "missing", "message": "metabolic concordance table not found."})

    write_validation_report(out_dir, rows)


