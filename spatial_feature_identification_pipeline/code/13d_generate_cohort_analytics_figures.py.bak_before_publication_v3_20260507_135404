    show_y_labels: bool = False,
    x_label_max_len: int = 18,
) -> None:
    """Create heatmap with an inferred feature-class annotation strip above columns."""
    if matrix.empty:
        raise ValueError("Empty matrix")

    class_order = [
        "Accessibility",
        "Hotspot",
        "Pairwise / distance",
        "Motif",
        "Gradient",
        "Metabolic / context",
        "Program / label",
        "Structure / region",
        "Other",
    ]
    class_colors = {
        "Accessibility": "#4C78A8",
        "Hotspot": "#F58518",
        "Pairwise / distance": "#54A24B",
        "Motif": "#B279A2",
        "Gradient": "#E45756",
        "Metabolic / context": "#72B7B2",
        "Program / label": "#EECA3B",
        "Structure / region": "#9D755D",
        "Other": "#BAB0AC",
    }

    feature_classes = [infer_feature_class(c) for c in matrix.columns]
    class_to_idx = {name: i for i, name in enumerate(class_order)}
    strip = np.array([[class_to_idx.get(c, class_to_idx["Other"]) for c in feature_classes]])

    import matplotlib.colors as mcolors
    cmap = mcolors.ListedColormap([class_colors[name] for name in class_order])

    fig_w = max(8, min(18, matrix.shape[1] * 0.28 + 4))
    fig_h = max(6, min(18, matrix.shape[0] * 0.11 + 4.4))
