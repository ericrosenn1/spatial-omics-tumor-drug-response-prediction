def get_label_frequency_table(label_counts_df: pd.DataFrame | None, scored_df: pd.DataFrame | None) -> pd.DataFrame:
    if label_counts_df is not None and "label" in label_counts_df.columns:
        df = label_counts_df.copy()
        value_col = "fraction_positive" if "fraction_positive" in df.columns else None
        if value_col is None and "n_positive" in df.columns:
            value_col = "n_positive"
        if value_col is None:
            raise ValueError("label_counts table has label column but no fraction_positive or n_positive")
        out = pd.DataFrame({
            "label": df["label"].astype(str),
            "value": pd.to_numeric(df[value_col], errors="coerce").fillna(0),
            "value_type": value_col,
        })
    elif scored_df is not None:
        label_cols = [c for c in scored_df.columns if str(c).startswith("label__")]
        if not label_cols:
            raise ValueError("No label columns found")
        out = pd.DataFrame({
            "label": label_cols,
            "value": [float(pd.to_numeric(scored_df[c], errors="coerce").fillna(0).astype(bool).mean()) for c in label_cols],
            "value_type": "fraction_positive",
        })
    else:
        raise ValueError("No label source available")
    out["clean_label"] = out["label"].map(clean_text_label)
    out["category"] = out["label"].map(collapse_label_category)
    return out.sort_values("value", ascending=False)


