def safe_col(df: pd.DataFrame | None, candidates: list[str]) -> str | None:
    if df is None:
        return None
    lower_map = {str(c).lower(): c for c in df.columns}
    for candidate in candidates:
        if candidate in df.columns:
            return candidate
        if candidate.lower() in lower_map:
            return lower_map[candidate.lower()]
    return None


def require_column(df: pd.DataFrame, column: str, table_name: str) -> None:
    if column not in df.columns:
        raise ValueError(f"{table_name} is missing required column: {column}")


def clean_text_label(value: str) -> str:
    label = str(value)
    for prefix in ("label__", "score__", "hotspot__", "access_", "access__", "metabolic_module__", "context_module__"):
        if label.startswith(prefix):
            label = label[len(prefix):]
    label = label.replace("__", "_")
    label = label.replace("_", " ")
    label = label.replace("ecm", "ECM")
    label = label.replace("pdac", "PDAC")
    label = label.replace("oxphos", "OXPHOS")
    label = label.replace("b plasma", "B/plasma")
    label = label.replace("t cell", "T-cell")
    label = label.replace("myeloid macrophage", "myeloid/macrophage")
    label = label.replace("angiogenic vascular", "angiogenic/vascular")
    label = label.replace("tumor", "tumor")
    label = re.sub(r"\s+", " ", label).strip()
    return label[:1].upper() + label[1:] if label else label


def clean_feature_label(value: str, max_len: int = 42) -> str:
    label = str(value)
    replacements = [
        ("hotspot__", "hotspot: "),
        ("access_", "access: "),
        ("access__", "access: "),
        ("motif__", "motif: "),
        ("pair_", "pair: "),
        ("pair__", "pair: "),
        ("gradient__", "gradient: "),
        ("metabolic_module__", "metabolic: "),
        ("context_module__", "context: "),
        ("concordance__", "concordance: "),
        ("structure_region__", "region: "),
        ("program_summary__", "program: "),
        ("label__", "label: "),
    ]
    for old, new in replacements:
        if label.startswith(old):
            label = new + label[len(old):]
            break
    label = label.replace("__", "_").replace("_", " ")
    label = label.replace("ecm", "ECM").replace("oxphos", "OXPHOS")
    label = label.replace("dist", "distance").replace("frac", "fraction")
    label = re.sub(r"\s+", " ", label).strip()
    if len(label) > max_len:
        label = label[: max_len - 1].rstrip() + "…"
    return label


def wrap_labels(labels: list[str], max_len: int = 24) -> list[str]:
    out = []
    for label in labels:
        label = str(label)
        if len(label) <= max_len:
            out.append(label)
        else:
            out.append("\n".join(textwrap.wrap(label, max_len)))
    return out


def collapse_label_category(raw_label: str) -> str:
    x = str(raw_label).lower()
    x = x.replace("label__", "")
    if "immune_excluded" in x or "excluded" in x:
        return "Immune excluded"
    if "immune_desert" in x or "desert" in x:
        return "Immune desert"
    if "immune" in x or "t_cell" in x or "b_plasma" in x:
        return "Immune enriched"
    if "myeloid" in x or "macrophage" in x:
        return "Myeloid/macrophage"
    if "fibroblast" in x or "stromal" in x or "ecm" in x or "barrier" in x or "cold" in x:
        return "Stromal/ECM barrier"
    if "vascular" in x or "endothelial" in x or "angiogenic" in x:
        return "Angiogenic/vascular"
    if "hypoxia" in x or "hypoxic" in x:
        return "Hypoxia"
    if "prolifer" in x or "cycling" in x:
        return "Proliferation"
    if "tumor" in x or "epithelial" in x:
        return "Tumor epithelial"
    return "Other / mixed"


def is_excluded_feature(column: str) -> bool:
    col = str(column)
    low = col.lower()
    if low in EXACT_EXCLUDE_COLUMNS:
        return True
    if low.endswith("_id") and low not in {"spatial_id"}:
        return True
    if low.startswith(EXCLUDE_PREFIXES):
        return True
    if any(term in low for term in EXCLUDE_SUBSTRINGS):
        return True
    return False


def retention_mask_from_manifest(feature_manifest: pd.DataFrame) -> pd.Series:
    keep = pd.Series(True, index=feature_manifest.index)
    retention_col = safe_col(feature_manifest, RETENTION_COLUMN_CANDIDATES)
    if retention_col is not None:
        values = feature_manifest[retention_col]
        if pd.api.types.is_bool_dtype(values):
            keep &= values.fillna(False)
        else:
            text = values.astype(str).str.lower().str.strip()
            negative = text.isin({
                "false", "0", "no", "n", "drop", "dropped", "remove", "removed",
                "exclude", "excluded", "filtered", "not_retained", "not retained", "fail", "failed"
            })
            positive = text.isin({
                "true", "1", "yes", "y", "keep", "kept", "retain", "retained",
                "include", "included", "ok", "pass", "passed", "model", "model_ready"
            })
            if positive.any():
                keep &= positive
            else:
                keep &= ~negative
    return keep


def feature_columns_from_manifest(model_df: pd.DataFrame, feature_manifest: pd.DataFrame | None) -> list[str]:
    if feature_manifest is None or feature_manifest.empty:
        return []

    name_col = safe_col(feature_manifest, FEATURE_NAME_CANDIDATES)
    if name_col is None:
        return []

    keep_mask = retention_mask_from_manifest(feature_manifest)
    candidate_names = feature_manifest.loc[keep_mask, name_col].astype(str).tolist()
    cols = [c for c in candidate_names if c in model_df.columns and not is_excluded_feature(c)]
    return list(dict.fromkeys(cols))


def numeric_feature_matrix(
    df: pd.DataFrame,
    feature_manifest: pd.DataFrame | None = None,
    sample_col: str = "sample_id",
) -> tuple[pd.DataFrame, list[str], list[str]]:
    if sample_col in df.columns:
        sample_ids = df[sample_col].astype(str).tolist()
    else:
        sample_ids = [f"row_{i}" for i in range(len(df))]

    manifest_cols = feature_columns_from_manifest(df, feature_manifest)
    if len(manifest_cols) >= 2:
        candidate_cols = manifest_cols
        source = "feature_manifest_retained_intersection"
    else:
        candidate_cols = [c for c in df.columns if c != sample_col and not is_excluded_feature(c)]
        source = "numeric_columns_after_exclusions"

    numeric = pd.DataFrame(index=df.index)
    dropped = []
    for col in candidate_cols:
        values = pd.to_numeric(df[col], errors="coerce")
        nonmissing_fraction = float(values.notna().mean())
        if nonmissing_fraction < MIN_NONMISSING_FRACTION:
            dropped.append(f"{col}|low_nonmissing")
            continue
        if values.nunique(dropna=True) < 2:
            dropped.append(f"{col}|constant")
            continue
        numeric[col] = values

    if numeric.empty:
        return numeric, sample_ids, [source]

    medians = numeric.median(axis=0, skipna=True)
    numeric = numeric.fillna(medians)
    numeric = numeric.replace([np.inf, -np.inf], np.nan).fillna(0.0)
    notes = [source, f"dropped_after_qc={len(dropped)}"]
    return numeric, sample_ids, notes


def standardize_matrix(matrix: pd.DataFrame) -> np.ndarray:
    arr = matrix.to_numpy(dtype=float)
    if HAS_SKLEARN:
        return StandardScaler().fit_transform(arr)
    mean = np.nanmean(arr, axis=0)
    std = np.nanstd(arr, axis=0)
    std[std == 0] = 1.0
    return (arr - mean) / std


def save_figure(fig: plt.Figure, path: Path) -> None:
    ensure_dir(path.parent)
    fig.tight_layout()
    fig.savefig(path, dpi=FIG_DPI, bbox_inches="tight")
    plt.close(fig)


def write_table(df: pd.DataFrame, path: Path) -> None:
    ensure_dir(path.parent)
    df.to_csv(path, index=False)


def make_vertical_bar(labels: list[str], values: list[float], title: str, ylabel: str, out_path: Path, rotation: int = 45) -> None:
    fig, ax = plt.subplots(figsize=(max(7, len(labels) * 0.35), 5))
    ax.bar(range(len(labels)), values)
    ax.set_title(title)
    ax.set_ylabel(ylabel)
    ax.set_xticks(range(len(labels)))
    ax.set_xticklabels(wrap_labels(labels, 22), rotation=rotation, ha="right")
    ax.grid(axis="y", alpha=0.25)
    save_figure(fig, out_path)


def make_horizontal_bar(labels: list[str], values: list[float], title: str, xlabel: str, out_path: Path) -> None:
    fig_h = max(5, len(labels) * 0.32 + 1.5)
    fig, ax = plt.subplots(figsize=(8, fig_h))
    y = np.arange(len(labels))
    ax.barh(y, values)
    ax.set_yticks(y)
    ax.set_yticklabels(labels)
    ax.invert_yaxis()
    ax.set_title(title)
    ax.set_xlabel(xlabel)
    ax.grid(axis="x", alpha=0.25)
    save_figure(fig, out_path)


def make_horizontal_boxplot(data_by_group: dict[str, pd.Series], title: str, xlabel: str, out_path: Path) -> None:
    labels = []
    values = []
    for label, series in data_by_group.items():
        vals = pd.to_numeric(series, errors="coerce").dropna().to_numpy(dtype=float)
        if vals.size == 0:
            continue
        labels.append(str(label))
        values.append(vals)
    if not values:
        raise ValueError("No nonmissing values available for boxplot")
    fig_h = max(5, len(labels) * 0.42 + 1.5)
    fig, ax = plt.subplots(figsize=(8, fig_h))
    ax.boxplot(values, labels=labels, vert=False, showfliers=False)
    ax.set_title(title)
    ax.set_xlabel(xlabel)
    ax.grid(axis="x", alpha=0.25)
    save_figure(fig, out_path)


def make_hist(values: pd.Series, title: str, xlabel: str, out_path: Path, bins: int = 20) -> None:
    vals = pd.to_numeric(values, errors="coerce").dropna().to_numpy(dtype=float)
    if vals.size == 0:
        raise ValueError("No nonmissing values available for histogram")
    fig, ax = plt.subplots(figsize=(7, 5))
    ax.hist(vals, bins=bins)
    ax.set_title(title)
    ax.set_xlabel(xlabel)
    ax.set_ylabel("Sample count")
    ax.grid(axis="y", alpha=0.25)
    save_figure(fig, out_path)


def make_heatmap(
    matrix: pd.DataFrame,
    title: str,
    out_path: Path,
    cbar_label: str = "",
    show_y_labels: bool = True,
    x_label_max_len: int = 22,
) -> None:
    if matrix.empty:
        raise ValueError("Empty matrix")
    fig_w = max(7, min(18, matrix.shape[1] * 0.30 + 4))
    fig_h = max(5, min(18, matrix.shape[0] * 0.12 + 4))
    fig, ax = plt.subplots(figsize=(fig_w, fig_h))
    im = ax.imshow(matrix.to_numpy(dtype=float), aspect="auto", interpolation="nearest")
    ax.set_title(title)
    ax.set_xticks(range(matrix.shape[1]))
    ax.set_xticklabels(wrap_labels([clean_feature_label(c, 38) for c in matrix.columns], x_label_max_len), rotation=90)
    if show_y_labels:
        ax.set_yticks(range(matrix.shape[0]))
        ax.set_yticklabels(wrap_labels(list(matrix.index), 24))
    else:
        ax.set_yticks([])
        ax.set_ylabel(f"Samples (n={matrix.shape[0]})")
    cbar = fig.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
    if cbar_label:
        cbar.set_label(cbar_label)
    save_figure(fig, out_path)


