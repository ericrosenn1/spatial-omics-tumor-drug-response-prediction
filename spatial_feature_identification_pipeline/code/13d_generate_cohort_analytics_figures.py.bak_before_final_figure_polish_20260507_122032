def write_summary(path: Path, args: argparse.Namespace, output_root: Path, out_dir: Path, rows: list[dict], input_paths: dict[str, Path]) -> None:
    success = sum(1 for r in rows if r["status"] == "created")
    skipped = sum(1 for r in rows if r["status"] != "created")
    lines = [
        str(path),
        "",
        "Cohort analytics figure generation summary",
        "",
        f"Script: {SCRIPT_NAME}",
        f"Timestamp: {datetime.now().isoformat(timespec='seconds')}",
        f"Output root: {output_root}",
        f"Output folder: {out_dir}",
        "",
        "Important generation notes:",
        "  - PCA and heatmap use retained/intersecting feature-manifest columns when available.",
        "  - PCA and heatmap exclude IDs, metadata, treatment/teacher/response fields, QC/status fields, and low-information numeric columns.",
        "  - Figure 02 is a cluster-ordered heatmap, not a dendrogram clustermap.",
        "  - Label frequency is cleaned for readability, and an additional collapsed biological-category plot is produced.",
        "  - Glycolysis/hypoxia scatter includes Pearson r, p value when scipy.stats is available, regression line, and n.",
        "",
        "Input files:",
    ]
    for key, value in input_paths.items():
        lines.append(f"  {key}: {value} | exists={value.exists()}")
    lines.extend([
        "",
        f"Figures requested: {len(rows)}",
        f"Figures created: {success}",
        f"Figures skipped or failed: {skipped}",
        "",
        "Figure status:",
    ])
    for row in rows:
        lines.append(f"  {row['figure_id']}: {row['status']} | {row['message']} | {row['figure_path']}")
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def main() -> None:
    args = parse_args()
    pipeline_root = Path(args.pipeline_root).resolve()
    config_path = Path(args.config)
    if not config_path.is_absolute():
        config_path = pipeline_root / config_path
    output_root = resolve_output_root(pipeline_root, config_path)
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    out_dir = output_root / Path(args.output_subdir) / f"cohort_analytics_{stamp}"
    ensure_dir(out_dir / "figures")
    ensure_dir(out_dir / "tables")

    input_paths = {
        "model_input_numeric": output_root / "output_10_build_model_ready_table" / "model_input_numeric.csv",
        "feature_manifest": output_root / "output_10_build_model_ready_table" / "feature_manifest.csv",
        "scored_labeled": output_root / "output_04_score_and_label_slides" / "slide_features_scored_labeled.csv",
        "label_counts": output_root / "output_04_score_and_label_slides" / "label_counts.csv",
        "metabolic_concordance": output_root / "output_08_context_alignment_and_metabolic_concordance" / "slide_features_with_metabolic_concordance.csv",
        "motif_table": output_root / "output_09_build_motif_tables" / "all_motif_table.csv",
        "pair_table": output_root / "output_09_build_motif_tables" / "all_pair_table.csv",
        "accessibility_profiles": output_root / "output_06_build_accessibility_profiles" / "slide_accessibility_profiles.csv",
        "hotspot_summary": output_root / "output_07_append_hotspot_metrics" / "hotspot_slide_summary.csv",
    }

    print("=" * 60)
    print("Cohort analytics figure generation")
    print("=" * 60)
    print("Pipeline root:", pipeline_root)
    print("Config:", config_path)
    print("Output root:", output_root)
    print("Output folder:", out_dir)

    tables = {key: read_csv_if_exists(path) for key, path in input_paths.items()}
    rows: list[dict] = []

    def run_figure(figure_id: str, func, sources: list[str]) -> None:
        source_paths = [input_paths[s] for s in sources]
        missing = [s for s in sources if tables.get(s) is None]
        if missing:
            record_status(rows, figure_id, None, "skipped_missing_input", "missing input tables: " + ";".join(missing), source_paths)
            return
        try:
            out_path = func()
            record_status(rows, figure_id, out_path, "created", "ok", source_paths)
        except Exception as error:
            record_status(rows, figure_id, None, "failed", f"{type(error).__name__}: {error}", source_paths)

    run_figure(
        "01_pca_explained_variance",
        lambda: figure_pca_explained_variance(tables["model_input_numeric"], tables["feature_manifest"], out_dir, args.max_pca_components),
        ["model_input_numeric", "feature_manifest"],
    )
