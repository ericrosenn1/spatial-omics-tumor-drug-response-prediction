def figure_pca_explained_variance(model_df: pd.DataFrame, out_dir: Path, top_components: int) -> Path:
    """Generate PCA explained variance plot from model input numeric features."""
    matrix, _ = numeric_feature_matrix(model_df)

    if matrix.shape[0] < 3 or matrix.shape[1] < 2:
        raise ValueError("Need at least 3 samples and 2 numeric features for PCA")

    x = standardize_matrix(matrix)
    n_components = min(top_components, x.shape[0] - 1, x.shape[1])

    if HAS_SKLEARN:
        pca = PCA(n_components=n_components)
        pca.fit(x)
        explained = pca.explained_variance_ratio_
    else:
        _, s, _ = np.linalg.svd(x, full_matrices=False)
        variances = (s ** 2) / max(1, x.shape[0] - 1)
        explained = variances / variances.sum()
        explained = explained[:n_components]

    cumulative = np.cumsum(explained)
    table = pd.DataFrame({
        "component": np.arange(1, len(explained) + 1),
        "explained_variance_ratio": explained,
        "cumulative_explained_variance_ratio": cumulative,
    })

    write_table(table, out_dir / "tables" / "01_pca_explained_variance.csv")

    fig, ax = plt.subplots(figsize=(8, 5))
    ax.bar(table["component"], table["explained_variance_ratio"])
    ax.plot(table["component"], table["cumulative_explained_variance_ratio"], marker="o")
    ax.set_title("PCA explained variance")
    ax.set_xlabel("Principal component")
    ax.set_ylabel("Explained variance ratio")
    ax.set_ylim(0, max(1.0, float(np.nanmax(cumulative)) * 1.05))
    out_path = out_dir / "figures" / "01_pca_explained_variance.png"
    save_figure(fig, out_path)
    return out_path


def figure_top_variable_clustermap(model_df: pd.DataFrame, out_dir: Path, top_n: int) -> Path:
    """Generate clustered heatmap of top variable model features."""
    matrix, sample_ids = numeric_feature_matrix(model_df)

    if matrix.shape[0] < 2 or matrix.shape[1] < 2:
        raise ValueError("Need at least 2 samples and 2 numeric features for clustermap")

    variances = matrix.var(axis=0).sort_values(ascending=False)
    top_cols = variances.head(top_n).index.tolist()
    sub = matrix[top_cols].copy()

    z = pd.DataFrame(
        standardize_matrix(sub),
        index=sample_ids,
        columns=top_cols,
    )

    row_order = np.arange(z.shape[0])
    col_order = np.arange(z.shape[1])

    if HAS_SCIPY_CLUSTER and z.shape[0] >= 3 and z.shape[1] >= 3:
        with warnings.catch_warnings():
            warnings.simplefilter("ignore")
            row_dist = pdist(z.to_numpy(dtype=float), metric="euclidean")
            col_dist = pdist(z.T.to_numpy(dtype=float), metric="euclidean")

            if np.isfinite(row_dist).all() and np.any(row_dist > 0):
                row_order = leaves_list(linkage(row_dist, method="average"))

            if np.isfinite(col_dist).all() and np.any(col_dist > 0):
                col_order = leaves_list(linkage(col_dist, method="average"))

    clustered = z.iloc[row_order, col_order]

    write_table(
        pd.DataFrame({"feature": top_cols, "variance": variances.loc[top_cols].values}),
        out_dir / "tables" / "02_top_variable_features.csv",
    )

    out_path = out_dir / "figures" / "02_top_variable_feature_clustermap.png"
    make_heatmap(clustered, "Top variable feature clustermap", out_path, cbar_label="Z score")
    return out_path


def figure_program_score_distributions(scored_df: pd.DataFrame, out_dir: Path) -> Path:
