def read_csv_if_exists(path: Path) -> pd.DataFrame | None:
    """Read a CSV if it exists, otherwise return None."""
    if not path.exists():
        return None

    return pd.read_csv(path)


def require_column(df: pd.DataFrame, column: str, table_name: str) -> None:
    """Raise a clear error when a required column is missing."""
    if column not in df.columns:
        raise ValueError(f"{table_name} is missing required column: {column}")


def numeric_feature_matrix(df: pd.DataFrame, sample_col: str = "sample_id") -> tuple[pd.DataFrame, list[str]]:
    """Build a clean numeric feature matrix with median imputation."""
    if sample_col in df.columns:
        sample_ids = df[sample_col].astype(str).tolist()
        features = df.drop(columns=[sample_col]).copy()
    else:
        sample_ids = [f"row_{i}" for i in range(len(df))]
        features = df.copy()

    numeric = pd.DataFrame(index=df.index)

    for col in features.columns:
        values = pd.to_numeric(features[col], errors="coerce")
        nonmissing_fraction = float(values.notna().mean())

        if nonmissing_fraction < MIN_NONMISSING_FRACTION:
            continue

        if values.nunique(dropna=True) < 2:
            continue

        numeric[col] = values

    if numeric.empty:
        return numeric, sample_ids

    medians = numeric.median(axis=0, skipna=True)
    numeric = numeric.fillna(medians)

    numeric = numeric.replace([np.inf, -np.inf], np.nan)
    numeric = numeric.fillna(0.0)

    return numeric, sample_ids


def standardize_matrix(matrix: pd.DataFrame) -> np.ndarray:
    """Return z scored numeric matrix."""
    arr = matrix.to_numpy(dtype=float)

    if HAS_SKLEARN:
        return StandardScaler().fit_transform(arr)

    mean = np.nanmean(arr, axis=0)
    std = np.nanstd(arr, axis=0)
    std[std == 0] = 1.0
    return (arr - mean) / std


def safe_col(df: pd.DataFrame, candidates: list[str]) -> str | None:
    """Return the first present column from candidate names."""
    for col in candidates:
        if col in df.columns:
            return col
    return None


def columns_starting(df: pd.DataFrame, prefix: str) -> list[str]:
    """Return columns whose names start with a prefix."""
    return [col for col in df.columns if str(col).startswith(prefix)]


def extract_hotspot_feature_name(column: str, suffix: str) -> str:
    """Extract feature name from hotspot summary columns."""
    return str(column).replace("hotspot__", "").replace(suffix, "")


