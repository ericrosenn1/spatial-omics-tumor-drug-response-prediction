def save_figure(fig: plt.Figure, path: Path) -> None:
    """Save a matplotlib figure consistently and close it."""
    ensure_dir(path.parent)
    fig.tight_layout()
    fig.savefig(path, dpi=FIG_DPI, bbox_inches="tight")
    plt.close(fig)


def readable_labels(labels: list[str], max_len: int = 36) -> list[str]:
    """Wrap long axis labels for compact plotting."""
    out = []
    for label in labels:
        label = str(label)
        if len(label) <= max_len:
            out.append(label)
        else:
            out.append("\n".join(textwrap.wrap(label, max_len)))
    return out


def write_table(df: pd.DataFrame, path: Path) -> None:
    """Write a helper CSV table for a plotted figure."""
    ensure_dir(path.parent)
    df.to_csv(path, index=False)


def make_bar_plot(labels: list[str], values: list[float], title: str, ylabel: str, out_path: Path, rotation: int = 45) -> None:
    """Create a simple bar plot."""
    fig, ax = plt.subplots(figsize=(max(8, len(labels) * 0.38), 5))
    ax.bar(range(len(labels)), values)
    ax.set_title(title)
    ax.set_ylabel(ylabel)
    ax.set_xticks(range(len(labels)))
    ax.set_xticklabels(readable_labels(labels), rotation=rotation, ha="right")
    save_figure(fig, out_path)


def make_boxplot(data_by_group: dict[str, pd.Series], title: str, ylabel: str, out_path: Path) -> None:
    """Create a grouped boxplot from a dictionary of numeric series."""
    labels = []
    values = []

    for label, series in data_by_group.items():
        vals = pd.to_numeric(series, errors="coerce").dropna().to_numpy(dtype=float)
        if vals.size == 0:
            continue
        labels.append(str(label))
        values.append(vals)

    if not values:
        raise ValueError("No nonmissing values available for boxplot")

    fig, ax = plt.subplots(figsize=(max(8, len(labels) * 0.45), 5))
    ax.boxplot(values, labels=readable_labels(labels), showfliers=False)
    ax.set_title(title)
    ax.set_ylabel(ylabel)
    ax.tick_params(axis="x", rotation=45)
    save_figure(fig, out_path)


def make_hist(values: pd.Series, title: str, xlabel: str, out_path: Path, bins: int = 20) -> None:
    """Create a histogram from numeric values."""
    vals = pd.to_numeric(values, errors="coerce").dropna().to_numpy(dtype=float)
    if vals.size == 0:
        raise ValueError("No nonmissing values available for histogram")

    fig, ax = plt.subplots(figsize=(7, 5))
    ax.hist(vals, bins=bins)
    ax.set_title(title)
    ax.set_xlabel(xlabel)
    ax.set_ylabel("Count")
    save_figure(fig, out_path)


def make_heatmap(matrix: pd.DataFrame, title: str, out_path: Path, cbar_label: str = "") -> None:
    """Create a heatmap from a dataframe."""
    if matrix.empty:
        raise ValueError("Empty matrix")

    fig_w = max(7, min(18, matrix.shape[1] * 0.35 + 4))
    fig_h = max(5, min(18, matrix.shape[0] * 0.35 + 3))
    fig, ax = plt.subplots(figsize=(fig_w, fig_h))

    im = ax.imshow(matrix.to_numpy(dtype=float), aspect="auto")
    ax.set_title(title)
    ax.set_xticks(range(matrix.shape[1]))
    ax.set_yticks(range(matrix.shape[0]))
    ax.set_xticklabels(readable_labels(list(matrix.columns), 22), rotation=90)
    ax.set_yticklabels(readable_labels(list(matrix.index), 28))
    cbar = fig.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
    if cbar_label:
        cbar.set_label(cbar_label)

    save_figure(fig, out_path)


