def figure_mean_hotspot_fractions(hotspot_df: pd.DataFrame, out_dir: Path) -> Path:
    """Generate mean hotspot fraction plot."""
    fraction_cols = [
        col for col in hotspot_df.columns
        if str(col).startswith("hotspot__") and str(col).endswith("_fraction")
        and "contact" not in str(col)
        and "largest_component" not in str(col)
    ]

    if not fraction_cols:
        raise ValueError("No hotspot fraction columns found")

    summary_rows = []
    for col in fraction_cols:
        values = pd.to_numeric(hotspot_df[col], errors="coerce")
        summary_rows.append({
            "hotspot": extract_hotspot_feature_name(col, "_fraction"),
            "mean_fraction": float(values.mean()),
            "median_fraction": float(values.median()),
            "n_nonmissing": int(values.notna().sum()),
        })

    summary = pd.DataFrame(summary_rows).sort_values("mean_fraction", ascending=False)
    write_table(summary, out_dir / "tables" / "14_mean_hotspot_fractions.csv")

    out_path = out_dir / "figures" / "14_mean_hotspot_fractions.png"
    make_bar_plot(summary["hotspot"].tolist(), summary["mean_fraction"].tolist(), "Mean hotspot fractions", "Mean fraction", out_path)
    return out_path


