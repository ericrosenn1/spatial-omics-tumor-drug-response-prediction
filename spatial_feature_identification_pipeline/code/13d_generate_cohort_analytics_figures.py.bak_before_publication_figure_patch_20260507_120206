def figure_overall_metabolic_concordance(concordance_df: pd.DataFrame, out_dir: Path) -> Path:
    """Generate overall metabolic concordance distribution."""
    col = safe_col(concordance_df, ["concordance__overall_mean", "overall_metabolic_concordance"])

    if col is None:
        concordance_cols = [
            c for c in concordance_df.columns
            if str(c).startswith("concordance__") and not str(c).endswith("_flag") and str(c) != "concordance__overall_std"
        ]
        if not concordance_cols:
            raise ValueError("No concordance columns found")
        values = concordance_df[concordance_cols].apply(pd.to_numeric, errors="coerce").mean(axis=1, skipna=True)
        col = "mean_of_concordance_columns"
    else:
        values = pd.to_numeric(concordance_df[col], errors="coerce")

    table_cols = ["sample_id"] if "sample_id" in concordance_df.columns else []
    table = concordance_df[table_cols].copy() if table_cols else pd.DataFrame(index=concordance_df.index)
    table["overall_metabolic_concordance"] = values.values
    write_table(table, out_dir / "tables" / "18_overall_metabolic_concordance.csv")

    out_path = out_dir / "figures" / "18_overall_metabolic_concordance.png"
    make_hist(values, "Overall metabolic concordance", col, out_path)
    return out_path


# =========================
# Summary writers
# =========================

def write_manifest(rows: list[dict], path: Path) -> None:
    """Write figure manifest as CSV."""
    ensure_dir(path.parent)
    pd.DataFrame(rows).to_csv(path, index=False)


def write_summary(
    path: Path,
    args: argparse.Namespace,
    output_root: Path,
    out_dir: Path,
    rows: list[dict],
    input_paths: dict[str, Path],
) -> None:
    """Write text summary with path as first line."""
    success = sum(1 for r in rows if r["status"] == "created")
    skipped = sum(1 for r in rows if r["status"] != "created")

    lines = [
        str(path),
        "",
        "Cohort analytics figure generation summary",
        "",
        f"Script: {SCRIPT_NAME}",
        f"Timestamp: {datetime.now().isoformat(timespec='seconds')}",
        f"Output root: {output_root}",
        f"Output folder: {out_dir}",
        "",
        "Input files:",
    ]

    for key, value in input_paths.items():
        lines.append(f"  {key}: {value} | exists={value.exists()}")

    lines.extend([
        "",
        f"Figures requested: {len(EXPECTED_FIGURES)}",
        f"Figures created: {success}",
        f"Figures skipped or failed: {skipped}",
        "",
        "Figure status:",
    ])

    for row in rows:
        lines.append(f"  {row['figure_id']}: {row['status']} | {row['message']} | {row['figure_path']}")

    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


