def main() -> None:
    """Generate all requested cohort analytics figures from existing outputs."""
    args = parse_args()

    pipeline_root = Path(args.pipeline_root).resolve()
    config_path = Path(args.config)
    if not config_path.is_absolute():
        config_path = pipeline_root / config_path

    output_root = resolve_output_root(pipeline_root, config_path)

    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    out_dir = output_root / Path(args.output_subdir) / f"cohort_analytics_{stamp}"
    figure_dir = out_dir / "figures"
    table_dir = out_dir / "tables"

    ensure_dir(figure_dir)
    ensure_dir(table_dir)

    input_paths = {
        "model_input_numeric": output_root / "output_10_build_model_ready_table" / "model_input_numeric.csv",
        "feature_manifest": output_root / "output_10_build_model_ready_table" / "feature_manifest.csv",
        "scored_labeled": output_root / "output_04_score_and_label_slides" / "slide_features_scored_labeled.csv",
        "label_counts": output_root / "output_04_score_and_label_slides" / "label_counts.csv",
        "metabolic_concordance": output_root / "output_08_context_alignment_and_metabolic_concordance" / "slide_features_with_metabolic_concordance.csv",
        "motif_table": output_root / "output_09_build_motif_tables" / "all_motif_table.csv",
        "pair_table": output_root / "output_09_build_motif_tables" / "all_pair_table.csv",
        "accessibility_profiles": output_root / "output_06_build_accessibility_profiles" / "slide_accessibility_profiles.csv",
        "hotspot_summary": output_root / "output_07_append_hotspot_metrics" / "hotspot_slide_summary.csv",
    }

    print()
    print("=" * 60)
    print("Cohort analytics figure generation")
    print("=" * 60)
    print("Pipeline root:", pipeline_root)
    print("Config:", config_path)
    print("Output root:", output_root)
    print("Output folder:", out_dir)
    print()

    tables = {
        key: read_csv_if_exists(path)
        for key, path in input_paths.items()
    }

    rows: list[dict] = []

    def run_figure(figure_id: str, func, sources: list[str], *func_args) -> None:
        """Run one figure function and record success or failure."""
        source_paths = [input_paths[s] for s in sources]
        missing = [s for s in sources if tables.get(s) is None]

        if missing:
            record_status(
                rows,
                figure_id=figure_id,
                path=None,
                status="skipped_missing_input",
                message="missing input tables: " + ";".join(missing),
                sources=source_paths,
            )
            return

        try:
            out_path = func(*func_args)
            record_status(
                rows,
                figure_id=figure_id,
                path=out_path,
                status="created",
                message="ok",
                sources=source_paths,
            )
        except Exception as error:
            record_status(
                rows,
                figure_id=figure_id,
                path=None,
                status="failed",
                message=f"{type(error).__name__}: {error}",
                sources=source_paths,
            )

    run_figure(
        "01_pca_explained_variance",
        lambda: figure_pca_explained_variance(tables["model_input_numeric"], out_dir, args.max_pca_components),
        ["model_input_numeric"],
    )

    run_figure(
        "02_top_variable_feature_clustermap",
        lambda: figure_top_variable_clustermap(tables["model_input_numeric"], out_dir, args.top_n_features),
        ["model_input_numeric"],
    )

    run_figure(
        "03_program_score_distributions",
        lambda: figure_program_score_distributions(tables["scored_labeled"], out_dir),
        ["scored_labeled"],
    )

    run_figure(
        "04_label_frequency",
        lambda: figure_label_frequency(tables["label_counts"], tables["scored_labeled"], out_dir),
        ["label_counts", "scored_labeled"],
    )

    run_figure(
        "05_glycolysis_vs_hypoxia_context_scatter",
        lambda: figure_glycolysis_hypoxia_scatter(tables["metabolic_concordance"], out_dir),
        ["metabolic_concordance"],
    )

    run_figure(
        "06_motif_fraction_matrix_heatmap",
        lambda: figure_motif_fraction_matrix(tables["motif_table"], out_dir),
        ["motif_table"],
    )

    run_figure(
        "07_motif_fraction_by_motif",
        lambda: figure_motif_fraction_by_motif(tables["motif_table"], out_dir),
        ["motif_table"],
    )

    run_figure(
        "08_motif_fragmentation_by_motif",
        lambda: figure_motif_fragmentation_by_motif(tables["motif_table"], out_dir),
        ["motif_table"],
    )

    run_figure(
        "09_mean_centroid_distance_matrix_between_motifs",
        lambda: figure_mean_centroid_distance_matrix(tables["pair_table"], out_dir),
        ["pair_table"],
    )

    run_figure(
        "10_pairwise_motif_relationship_counts",
        lambda: figure_pairwise_relationship_counts(tables["pair_table"], out_dir),
        ["pair_table"],
    )

    run_figure(
        "11_accessibility_profile_label_counts",
        lambda: figure_accessibility_label_counts(tables["accessibility_profiles"], out_dir),
        ["accessibility_profiles"],
    )

    run_figure(
        "12_boundary_tumor_fraction_by_accessibility_profile",
        lambda: figure_boundary_tumor_fraction_by_profile(tables["accessibility_profiles"], out_dir),
        ["accessibility_profiles"],
    )

    run_figure(
        "13_penetration_graph_depth_by_accessibility_profile",
        lambda: figure_penetration_depth_by_profile(tables["accessibility_profiles"], out_dir),
        ["accessibility_profiles"],
    )

    run_figure(
        "14_mean_hotspot_fractions",
        lambda: figure_mean_hotspot_fractions(tables["hotspot_summary"], out_dir),
        ["hotspot_summary"],
    )

    run_figure(
        "15_angiogenic_vascular_hotspot_fragmentation",
        lambda: figure_hotspot_fragmentation(tables["hotspot_summary"], "angiogenic_vascular", "Angiogenic vascular", "15", out_dir),
        ["hotspot_summary"],
    )

    run_figure(
        "16_interferon_inflamed_hotspot_fragmentation",
        lambda: figure_hotspot_fragmentation(tables["hotspot_summary"], "interferon_inflamed", "Interferon inflamed", "16", out_dir),
        ["hotspot_summary"],
    )

    run_figure(
        "17_myeloid_macrophage_hotspot_fragmentation",
        lambda: figure_hotspot_fragmentation(tables["hotspot_summary"], "myeloid_macrophage", "Myeloid macrophage", "17", out_dir),
        ["hotspot_summary"],
    )

    run_figure(
        "18_overall_metabolic_concordance",
        lambda: figure_overall_metabolic_concordance(tables["metabolic_concordance"], out_dir),
        ["metabolic_concordance"],
    )

    manifest_path = out_dir / "cohort_analytics_figure_manifest.csv"
    summary_path = out_dir / "cohort_analytics_summary.txt"
    metadata_path = out_dir / "cohort_analytics_metadata.json"

    write_manifest(rows, manifest_path)
    write_summary(summary_path, args, output_root, out_dir, rows, input_paths)

    metadata = {
        "script": SCRIPT_NAME,
        "timestamp": stamp,
        "pipeline_root": str(pipeline_root),
        "config": str(config_path),
        "output_root": str(output_root),
        "output_folder": str(out_dir),
        "top_n_features": args.top_n_features,
        "max_pca_components": args.max_pca_components,
        "has_sklearn": HAS_SKLEARN,
        "has_scipy_cluster": HAS_SCIPY_CLUSTER,
        "figures_created": sum(1 for row in rows if row["status"] == "created"),
        "figures_requested": len(rows),
    }
    metadata_path.write_text(json.dumps(metadata, indent=2), encoding="utf-8")

    created = sum(1 for row in rows if row["status"] == "created")
    failed = [row for row in rows if row["status"] != "created"]

    print()
    print("=" * 60)
    print("Cohort analytics figure summary")
    print("=" * 60)
    print("Figures requested:", len(rows))
    print("Figures created:", created)
    print("Figures skipped or failed:", len(failed))
    print()
    print("Output folder:", out_dir)
    print("Figure folder:", figure_dir)
    print("Table folder:", table_dir)
    print("Manifest:", manifest_path)
    print("Summary:", summary_path)
    print("Metadata:", metadata_path)

    if failed:
        print()
        print("Skipped or failed figures:")
        for row in failed:
            print(f"  {row['figure_id']} | {row['status']} | {row['message']}")

    print()
    print("DONE")

    if not args.no_open:
        open_folder(out_dir)
        open_folder(figure_dir)


if __name__ == "__main__":
    with warnings.catch_warnings():
        warnings.simplefilter("ignore")
        main()
