    }

    table = pd.DataFrame({
        "program": list(data.keys()),
        "n_nonmissing": [int(v.notna().sum()) for v in data.values()],
        "mean": [float(v.mean()) for v in data.values()],
        "median": [float(v.median()) for v in data.values()],
    })
    write_table(table, out_dir / "tables" / "03_program_score_distribution_summary.csv")

    out_path = out_dir / "figures" / "03_program_score_distributions.png"
    make_boxplot(data, "Program score distributions", "Program score", out_path)
    return out_path


def figure_label_frequency(label_counts_df: pd.DataFrame, scored_df: pd.DataFrame | None, out_dir: Path) -> Path:
    """Generate label frequency plot from Step 04 label counts."""
    if label_counts_df is not None and "label" in label_counts_df.columns:
        labels = label_counts_df["label"].astype(str).tolist()
        value_col = "fraction_positive" if "fraction_positive" in label_counts_df.columns else None
        if value_col is None and "n_positive" in label_counts_df.columns:
            values = pd.to_numeric(label_counts_df["n_positive"], errors="coerce").fillna(0).tolist()
            ylabel = "Count"
        else:
            values = pd.to_numeric(label_counts_df[value_col], errors="coerce").fillna(0).tolist()
            ylabel = "Fraction positive"
    elif scored_df is not None:
        label_cols = [c for c in scored_df.columns if c.startswith("label__")]
        if not label_cols:
            raise ValueError("No label columns found")
        labels = label_cols
        values = [float(pd.to_numeric(scored_df[col], errors="coerce").fillna(0).astype(bool).mean()) for col in label_cols]
        ylabel = "Fraction positive"
        write_table(
            pd.DataFrame({"label": labels, "fraction_positive": values}),
            out_dir / "tables" / "04_label_frequency.csv",
        )
    else:
        raise ValueError("No label source available")

    out_path = out_dir / "figures" / "04_label_frequency.png"
    make_bar_plot(labels, values, "Label frequency", ylabel, out_path)
    return out_path


def figure_glycolysis_hypoxia_scatter(concordance_df: pd.DataFrame, out_dir: Path) -> Path:
    """Generate glycolysis versus hypoxia context scatter."""
    x_col = safe_col(concordance_df, [
        "metabolic_module__glycolysis",
        "metabolic_score__glycolysis_mean",
        "metabolism_score__glycolysis_mean",
    ])

    y_col = safe_col(concordance_df, [
        "context_module__hypoxia_context",
        "function_score__hypoxic_stress_mean",
        "hotspot__hypoxic_stress_fraction",
    ])

    if x_col is None or y_col is None:
        raise ValueError("Could not find glycolysis and hypoxia context columns")

    x = pd.to_numeric(concordance_df[x_col], errors="coerce")
    y = pd.to_numeric(concordance_df[y_col], errors="coerce")
    mask = x.notna() & y.notna()

    if int(mask.sum()) < 3:
        raise ValueError("Fewer than 3 nonmissing points")

    table_cols = ["sample_id"] if "sample_id" in concordance_df.columns else []
    table = concordance_df.loc[mask, table_cols].copy()
    table["glycolysis"] = x[mask].values
    table["hypoxia_context"] = y[mask].values
    write_table(table, out_dir / "tables" / "05_glycolysis_vs_hypoxia_context_scatter.csv")

    fig, ax = plt.subplots(figsize=(6.5, 5.5))
    ax.scatter(x[mask], y[mask], alpha=0.85)
    ax.set_title("Glycolysis versus hypoxia context")
    ax.set_xlabel(x_col)
    ax.set_ylabel(y_col)

    if int(mask.sum()) >= 3:
        corr = float(np.corrcoef(x[mask], y[mask])[0, 1])
        ax.text(0.02, 0.98, f"r = {corr:.3f}", transform=ax.transAxes, va="top")

    out_path = out_dir / "figures" / "05_glycolysis_vs_hypoxia_context_scatter.png"
    save_figure(fig, out_path)
    return out_path


