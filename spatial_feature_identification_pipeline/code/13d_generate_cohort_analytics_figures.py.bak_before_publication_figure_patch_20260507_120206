def parse_args() -> argparse.Namespace:
    """Parse command line arguments for cohort analytics figure generation."""
    parser = argparse.ArgumentParser(
        description="Generate supplemental cohort analytics graphics from existing pipeline outputs."
    )

    parser.add_argument(
        "--config",
        default=str(DEFAULT_CONFIG),
        help="Pipeline YAML config. Used to resolve output_root when available.",
    )

    parser.add_argument(
        "--pipeline-root",
        default=".",
        help="Pipeline root directory. Defaults to current working directory.",
    )

    parser.add_argument(
        "--output-subdir",
        default=str(DEFAULT_OUTPUT_SUBDIR),
        help="Subfolder under output_root where this script writes figures.",
    )

    parser.add_argument(
        "--top-n-features",
        type=int,
        default=DEFAULT_TOP_N_FEATURES,
        help="Number of top variable features for the clustermap.",
    )

    parser.add_argument(
        "--max-pca-components",
        type=int,
        default=DEFAULT_MAX_PCA_COMPONENTS,
        help="Maximum PCA components to compute and plot.",
    )

    parser.add_argument(
        "--no-open",
        action="store_true",
        help="Do not open the output folder after completion.",
    )

    return parser.parse_args()


def read_yaml_output_root(config_path: Path) -> Path | None:
    """Read output_root from YAML config using PyYAML when available, with a simple fallback."""
    if not config_path.exists():
        return None

    try:
        import yaml
        with open(config_path, "r", encoding="utf-8") as handle:
            cfg = yaml.safe_load(handle) or {}
        value = cfg.get("output_root")
        if value:
            return Path(str(value))
    except Exception:
        pass

    try:
        for line in config_path.read_text(encoding="utf-8").splitlines():
            stripped = line.strip()
            if stripped.startswith("output_root:"):
                value = stripped.split(":", 1)[1].strip().strip("'").strip('"')
                if value:
                    return Path(value)
    except Exception:
        return None

    return None


def resolve_output_root(pipeline_root: Path, config_path: Path) -> Path:
    """Resolve the pipeline output root from config, falling back to pipeline_root/outputs."""
    config_output = read_yaml_output_root(config_path)

    if config_output is None:
        return pipeline_root / "outputs"

    if config_output.is_absolute():
        return config_output

    candidate = pipeline_root / config_output
    return candidate.resolve()


def ensure_dir(path: Path) -> None:
    """Create a directory and its parents when needed."""
    path.mkdir(parents=True, exist_ok=True)


def open_folder(path: Path) -> None:
    """Open a folder in the platform file browser when possible."""
    try:
        if os.name == "nt":
            os.startfile(str(path))
        elif sys.platform == "darwin":
            os.system(f'open "{path}"')
        else:
            os.system(f'xdg-open "{path}" >/dev/null 2>&1')
    except Exception:
        pass


